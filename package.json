{
  "name": "gitcoral",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "prestart": "node scripts/gen-version.mjs",
    "start": "ng serve",
    "prebuild": "node scripts/gen-version.mjs",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --no-watch",
